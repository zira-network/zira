# ZIRA — environment variables. Copy to .env and adjust. All are optional; sane defaults apply.
# Booleans accept 1/0. Times are in milliseconds unless noted.

# ── Network ─────────────────────────────────────────────────────────────────
ZIRA_NETWORK=mainnet            # devnet | testnet | mainnet (desktop default: mainnet)
# ZIRA_FOUNDER_KEY=             # hex founder private key → run as founder/bootstrap if it matches genesis
# ZIRA_FOUNDER_ADDRESS=         # override founder address (advanced)
# ZIRA_STEWARD=1                # devnet only: use the well-known devnet steward identity
# ZIRA_SEED=1                   # devnet only: seed observations/queries for local demos
# ZIRA_RESET=1                  # wipe ledger + provider/zti state and start fresh
# ZIRA_FULL_SYNC=1              # replay from genesis instead of fast-sync
# ZIRA_FAST_SYNC=1              # adopt peer snapshots (default on devnet/testnet, off on mainnet)
# ZIRA_DATA_DIR=                # data directory (default ~/.zira/<network>)
# ZIRA_ANNOUNCE=                # public multiaddr to advertise, e.g. /ip4/1.2.3.4/tcp/9645
# ZIRA_BOOTSTRAP=               # comma-separated peer multiaddrs to dial on startup

# ── RPC / Console ───────────────────────────────────────────────────────────
ZIRA_RPC_HOST=127.0.0.1
ZIRA_RPC_PORT=8645
# ZIRA_RPC_ADMIN_TOKEN=         # required for sensitive POST routes when RPC host is public
# ZIRA_SERVE_CONSOLE=0          # disable serving the bundled Console (headless node)
# ZIRA_CONSOLE_DIR=             # explicit Console static dir override
ZIRA_LOG_LEVEL=info             # debug | info | warn | error

# ── Node participation (Tier 1) ─────────────────────────────────────────────
ZIRA_OBSERVE=1                  # submit PoR observations (off = pure relay, no observation rewards)
ZIRA_HARDWARE_DETECT=1          # run GPU/CPU detection at startup (advisory only; set 0 in CI)
ZIRA_OBS_RATE_LIMIT=20          # max observations per minute per identity
ZIRA_TASK_REAP_MS=30000         # interval between expired-task scans

# ── Inference provider (Tier 2) ─────────────────────────────────────────────
ZIRA_PROVIDE=0                  # enable inference serving
ZIRA_PROVIDE_ENDPOINT=http://localhost:11434/v1   # any OpenAI-compatible endpoint (Ollama, LM Studio, …)
ZIRA_PROVIDE_MODEL=mistral      # model name to pass to the endpoint
# ZIRA_PROVIDE_DOMAINS=general,reasoning           # comma-separated; empty = serve all
# ZIRA_PROVIDE_LABEL=My provider
ZIRA_PROVIDE_STREAMING=0        # advertise SSE streaming support

# ── Advanced / founder ──────────────────────────────────────────────────────
# ZIRA_SELF_CONTAINED=1         # activate FounderServices (model management, node-llama-cpp)
                                # requires a separate node-llama-cpp install
