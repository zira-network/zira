{
  "name": "zira-final",
  "private": true,
  "version": "1.9.14",
  "description": "ZIRA. A shared AI network that people run together, with no company in the middle. Peer to peer ZIRA Core nodes with a Console synced by peers.",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build:protocol": "pnpm --filter @zira/protocol build",
    "test:protocol": "pnpm --filter @zira/protocol test",
    "gen:vectors": "pnpm --filter @zira/protocol gen:vectors",
    "build:node": "pnpm --filter @zira/node build",
    "test:node": "pnpm --filter @zira/node test",
    "build:console": "pnpm --filter @zira/console build",
    "dev:console": "pnpm --filter @zira/console dev",
    "build": "pnpm build:protocol && pnpm build:node && pnpm build:console",
    "check:founder-gate": "node scripts/check-founder-gate.mjs",
    "test": "pnpm test:protocol && pnpm test:node",
    "node": "pnpm --filter @zira/node start",
    "node:windows": "powershell -ExecutionPolicy Bypass -File scripts/run-node.ps1",
    "open:node-ports": "powershell -ExecutionPolicy Bypass -File scripts/open-node-ports.ps1 -MainnetMesh -AutoElevate",
    "open:public-node-ports": "powershell -ExecutionPolicy Bypass -File scripts/open-public-node-ports.ps1 -MainnetMesh",
    "testnet": "node scripts/run-testnet.mjs",
    "stop:zira": "powershell -ExecutionPolicy Bypass -File scripts/stop-zira-ports.ps1",
    "clear:runtime-caches": "powershell -ExecutionPolicy Bypass -File scripts/clear-runtime-caches.ps1",
    "launch:mainnet:fresh": "powershell -ExecutionPolicy Bypass -File scripts/launch-mainnet-fresh.ps1",
    "launch:mainnet:authority": "powershell -ExecutionPolicy Bypass -File scripts/launch-mainnet-authority.ps1 -Launch",
    "launch:mainnet:extra-nodes": "powershell -ExecutionPolicy Bypass -File scripts/launch-extra-mainnet-nodes.ps1",
    "prepare:launch": "powershell -ExecutionPolicy Bypass -File scripts/prepare-launch.ps1",
    "prepare:web-gui": "powershell -ExecutionPolicy Bypass -File scripts/prepare-web-gui.ps1",
    "provide:launch-models": "node scripts/provide-launch-models.mjs",
    "download:launch-models": "powershell -ExecutionPolicy Bypass -File scripts/download-and-provide-launch-models.ps1",
    "watch:launch-models": "powershell -ExecutionPolicy Bypass -File scripts/watch-launch-model-readiness.ps1",
    "fund:launch-resonator": "node scripts/fund-launch-resonator.mjs",
    "seed:launch-resonators": "node scripts/seed-launch-resonators.mjs",
    "seed:extra-resonators": "node scripts/seed-extra-resonators.mjs",
    "seed:node-resonators": "node scripts/seed-node-resonators.mjs",
    "pulse:resonators": "node scripts/pulse-resonator-coordination.mjs",
    "seed:bootstrap-registry": "node scripts/seed-bootstrap-registry.mjs",
    "settle:launch-miners": "node scripts/settle-launch-miners.mjs",
    "watch:launch-miner-earnings": "powershell -ExecutionPolicy Bypass -File scripts/watch-launch-miner-earnings.ps1",
    "check:launch-models": "powershell -ExecutionPolicy Bypass -File scripts/check-launch-models.ps1",
    "check:field": "powershell -ExecutionPolicy Bypass -File scripts/check-field-readiness.ps1 -SmokeQuery",
    "check:public-bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/check-public-bootstrap.ps1",
    "check:new-user-sync": "powershell -ExecutionPolicy Bypass -File scripts/check-new-user-sync.ps1",
    "prepare:bootstrap-upload": "powershell -ExecutionPolicy Bypass -File scripts/prepare-bootstrap-upload.ps1",
    "download:steward-bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/download-steward-bootstrap.ps1",
    "check:release-hygiene": "powershell -ExecutionPolicy Bypass -File scripts/check-release-hygiene.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}