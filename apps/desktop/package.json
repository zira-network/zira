{
  "name": "@zira/desktop",
  "private": true,
  "version": "2.9.0",
  "author": "ZIRA",
  "description": "ZIRA desktop app. Runs a full ZIRA Core node (with mining) and the Console in one window.",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:dir": "electron-builder --win dir",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "network.zira.desktop",
    "productName": "ZIRA",
    "asar": false,
    "publish": [
      {
        "provider": "github",
        "owner": "zira-network",
        "repo": "zira"
      }
    ],
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../../node/dist",
        "to": "core"
      },
      {
        "from": "../../node/public",
        "to": "core/public"
      },
      {
        "from": "llama-bundle/node_modules",
        "to": "core/node_modules"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Network"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities"
    }
  }
}
